{
  "$schema": "./node_modules/@biomejs/biome/configuration_schema.json",
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true
  },
  "files": {
    "ignoreUnknown": true,
    "includes": [
      "packages/**/*.ts",
      "apps/site/**/*.ts",
      "apps/site/styles.css",
      "apps/site/index.html",
      "package.json",
      "**/packages/**/package.json",
      "**/apps/**/package.json",
      "tsconfig.json",
      "tsconfig.base.json",
      "**/packages/**/tsconfig.json",
      "**/apps/**/tsconfig.json",
      "biome.json",
      "test-setup.ts"
    ]
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true
    }
  },
  "overrides": [
    {
      "includes": ["packages/elements/src/glitch/*.ts"],
      "linter": {
        "rules": {
          "correctness": {
            "noUnusedVariables": "off"
          }
        }
      }
    }
  ]
}
