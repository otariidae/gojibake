{
  "name": "gojibake",
  "private": true,
  "packageManager": "bun@1.3.11",
  "scripts": {
    "prebuild": "rm -rf dist",
    "build": "bun build ./index.html --outdir ./dist --target browser",
    "dev": "bun ./index.html",
    "check:fix": "biome check . --write",
    "check": "biome check . && bun run build",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.8",
    "typescript": "^5.9.2"
  }
}
